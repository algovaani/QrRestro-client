# Dev only — backend URL for Vite proxy
VITE_DEV_API=http://localhost:5000

# Production split deploy (client on qrrestro-client.onrender.com, API elsewhere):
# Set to your BACKEND URL including /api — required for admin + bill PDF links
# Example: VITE_API_URL=https://qrrestro-api.onrender.com/api
# Leave empty when one server serves both client and /api on the same origin
VITE_API_URL=

# Optional: override Socket.IO server (defaults to same origin / VITE_API_URL origin)
VITE_SOCKET_URL=

# Optional: same as API server origin if VITE_API_URL is not set (bill PDF WhatsApp links)
# Example: VITE_PUBLIC_APP_URL=https://qrrestro-api.onrender.com
VITE_PUBLIC_APP_URL=

# --- Render API service env (set on backend, not client) ---
# PUBLIC_API_URL=https://qrrestro-api.onrender.com
# CLIENT_URL=https://qrrestro-client.onrender.com
