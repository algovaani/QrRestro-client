# Dev only — backend URL for Vite proxy
VITE_DEV_API=http://localhost:5000
# Production: leave empty when API is same origin (server serves client + /api)
VITE_API_URL=
# Optional: override Socket.IO server (defaults to same origin / VITE_API_URL origin)
VITE_SOCKET_URL=
# Optional: public URL for bill links on WhatsApp (LAN IP in dev, e.g. http://192.168.1.5:5173)
VITE_PUBLIC_APP_URL=
