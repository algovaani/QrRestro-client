# Dev only — backend URL for Vite proxy
VITE_DEV_API=http://localhost:5000
# Production split deploy: backend URL including /api (e.g. https://your-api.onrender.com/api)
# Leave empty when the server serves both client and /api on the same origin
VITE_API_URL=
# Optional: override Socket.IO server (defaults to same origin / VITE_API_URL origin)
VITE_SOCKET_URL=
# Optional: override API origin for bill PDF links (defaults to VITE_API_URL origin)
VITE_PUBLIC_APP_URL=
